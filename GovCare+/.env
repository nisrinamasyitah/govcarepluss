# reCAPTCHA v2 site key
# For development/localhost: using Google's official test key (always passes, works on any domain)
# For production: replace with your real site key from https://www.google.com/recaptcha/admin
# IMPORTANT: also add your production domain in the reCAPTCHA admin console
VITE_RECAPTCHA_SITE_KEY=6LeojvAsAAAAD44gWxVbf3ZKFHgEUvNH4YhVLBc

# AES-256-GCM field-level encryption key for sensitive PII (phone, IC number).
# IMPORTANT: Replace this with a strong random value before deploying to production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Never commit the production value — inject it as an environment secret in your CI/CD pipeline.
VITE_ENCRYPTION_KEY=change-this-to-a-random-32-byte-hex-string-before-production
